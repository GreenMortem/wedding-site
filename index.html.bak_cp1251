            <div class="hero__rings"></div>
          </div>
        </section>

        <section class="layout layout--top">
          <article class="card card--place">
            <div class="card__header">
              <span class="card__label">ћесто</span>
              <h2 class="card__title">ћесто</h2>
            </div>
