              <div class="place-item">
                <div class="place-item__left">
                  <div class="place-item__time" id="regTime">11:20</div>
                  <div class="place-item__label">регистраци€</div>
                </div>
                <div class="place-item__info">
                  <div class="place-item__name" id="regTitle">ƒворец бракосочетани€</div>
                  <div class="place-item__address" id="regAddress">пр. Ћенина, 11, Ѕарнаул, јлтайский край, –осси€, 656049</div>
                  <a class="btn btn--ghost" id="regMapBtn" href="#" target="_blank" rel="noreferrer">на карте</a>
                </div>
              </div>

              <div class="place-item">
