            </div>
            <p class="card__text">
              ѕросим подтвердить своЄ присутствие до <span class="underline" id="rsvpDeadline">17.08.2026</span>.
            </p>
            <form class="rsvp-form" id="rsvpForm">
              <div class="form-group">
                <label for="fullName">¬аше им€ и фамили€</label>
                <input type="text" id="fullName" name="fullName" autocomplete="name" required />
              </div>

              <div class="form-group">
                <label for="phoneOrTelegram">“елефон</label>
                <input type="text" id="phoneOrTelegram" name="phoneOrTelegram" autocomplete="tel" required />
              </div>

              <div class="form-group">
                <label for="status">—можете прийти?</label>
                <select id="status" name="status" required>
                  <option value="" selected disabled>¬ыберите</option>
                  <option value="yes">ƒа, буду</option>
                  <option value="no">  сожалению, не смогу</option>
                </select>
              </div>

              <div class="form-group" id="alcoholField">
                <label>ѕредпочтени€ по алкоголю</label>
                <div class="checks">
                  <label class="check"><input type="checkbox" name="alcoholChoices" value="wine_red" />  расное вино</label>
                  <label class="check"><input type="checkbox" name="alcoholChoices" value="wine_white" /> Ѕелое вино</label>
                  <label class="check"><input type="checkbox" name="alcoholChoices" value="strong_alcohol" />  репкий алкоголь</label>
                  <label class="check"><input type="checkbox" name="alcoholChoices" value="champagne" /> Ўампанское</label>
                  <label class="check"><input type="checkbox" name="alcoholChoices" value="non_alcohol" /> Ќе употребл€ю алкоголь</label>
                </div>
              </div>

              <div class="form-group" id="foodField">
                <label for="foodNotes">јллерги€ (если есть)</label>
                <textarea id="foodNotes" name="foodNotes" rows="3"></textarea>
              </div>

              <div class="form-group" id="commentField">
                <label for="comment"> омментарий</label>
                <textarea id="comment" name="comment" rows="2"></textarea>
              </div>

              <button class="btn btn--primary" type="submit" id="rsvpSubmit">отправить</button>
              <div class="status-message" id="rsvpNote" role="status" aria-live="polite"></div>
            </form>
          </article>

          <article class="card card--contacts">
